APP_NAME="Ajudy"
APP_ENV=local
APP_KEY=base64:GERA_COM_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://silvaalmeida.ajudy.local.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Conexão central (landlord) ─────────────────────────────────────────────
# Usada APENAS para resolver o tenant pelo subdomínio no middleware
DB_CONNECTION=landlord
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ajudy_landlord
DB_USERNAME=root
DB_PASSWORD=

# ── Cache ──────────────────────────────────────────────────────────────────
# Em produção, use Redis para melhor performance
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
